# ============================================
# GesTime – .gitignore principal
# ============================================

# ---------- dependencias ----------
node_modules/
vendor/

# ---------- builds / compilados ----------
dist/
build/
web/public/build/
web/public/hot

# ---------- entorno y credenciales ----------
.env
.env.*
!.env.example
*.key
*.pem
*.p12

# ---------- dumps de base de datos ----------
*.sql
!web/mysql/creacion_tablas.sql

# ---------- logs ----------
*.log
storage/logs/

# ---------- sistema operativo ----------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---------- IDEs / editores ----------
.idea/
.vscode/
*.code-workspace
.fleet/
.nova/
.zed/
*.swp
*.swo
*~

# ---------- caché / temporales ----------
*.cache
*.phpunit.result.cache
.phpunit.cache/
.phpactor.json
bootstrap/cache/*.php

# ---------- empaquetados ----------
*.zip
*.tar.gz
*.rar

# ---------- IA / asistentes ----------
.github/instructions/
.github/copilot*
.copilot/
.cursor/
.windsurf/
.aider*
.continue/
.codeium/
.tabnine*
.sourcery*
codex.md
AGENTS.md
*.prompts
*.prompt

# ---------- misc ----------
Homestead.json
Homestead.yaml
auth.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
